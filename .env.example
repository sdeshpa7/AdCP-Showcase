# ── Protocol Configuration ──
# Secret authorization token for secure MCP handshakes
ADCP_AUTH_TOKEN=your_secure_random_token_here
ADCP_TEST_AGENT_URL=https://test-agent.adcontextprotocol.org/mcp

# ── Buyer Agents (Gemma via Google AI Studio) ──
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
BUYER_LLM_MODEL=models/gemma-2-27b-it

# ── Seller Agents (Grok / Llama) ──
# Get your key at: https://console.x.ai
XAI_API_KEY=your_xai_api_key_here
SELLER_LLM_MODEL=llama-3.3-70b-versatile
